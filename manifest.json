{
  "manifest_version": 3,
  "name": "Audio Sampler",
  "short_name": "Audio Sampler",
  "version": "1.0.0",
  "description": "Instantly record audio from any browser tab and export it as a high-quality WAV file — no setup required.",
  "author": "Audio Sampler",
  "homepage_url": "https://github.com/itsuzef/audio-sampler",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Audio Sampler — Record tab audio",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
